1- Soru: E-ticaret Sepet Sistemi 
class Urun: 
    def __init__(self, isim, fiyat, stok): 
        self.isim = isim 
        self.fiyat = fiyat 
        self.stok = stok 
 
class Sepet: 
    def __init__(self): 
        # Ürünleri ve adetlerini tutmak için sözlük kullanmak en 
mantıklısı 
        self.urunler = {}  
 
    def urun_ekle(self, urun, adet=1): 
        if urun.stok >= adet: 
            if urun in self.urunler: 
                self.urunler[urun] += adet 
            else: 
                self.urunler[urun] = adet 
             
            urun.stok -= adet 
            print(f"{adet} adet {urun.isim} sepete eklendi.") 
        else: 
            print(f"Yeterli stok yok! Mevcut {urun.isim} stoğu: 
{urun.stok}") 
 
    def urun_sil(self, urun, adet=1): 
        if urun in self.urunler: 
            if self.urunler[urun] <= adet: 
                # Sepettekinden fazla veya eşit silinmek isteniyorsa 
ürünü sepetten tamamen çıkar 
                iade_adet = self.urunler[urun] 
                del self.urunler[urun] 
                urun.stok += iade_adet 
                print(f"{urun.isim} sepetten tamamen çıkarıldı.") 
            else: 
                self.urunler[urun] -= adet 
                urun.stok += adet 
                print(f"{adet} adet {urun.isim} sepetten çıkarıldı.") 
        else: 
            print("Bu ürün zaten sepette yok.") 
 
    def toplam_tutar(self): 
        tutar = 0 
        for urun, adet in self.urunler.items(): 
            tutar += urun.fiyat * adet 
        return tutar 
 
2. Soru: Banka Hesabı Sistemi 
class BankaHesabi: 
    def __init__(self, isim, bakiye=0): 
        self.isim = isim 
        self.bakiye = bakiye 
        self.hareket_gecmisi = [] 
 
    def islem_kaydet(self, *args): 
        # İstenen *args kullanımını işlemleri kaydederken 
kullanabiliriz 
        for islem in args: 
            self.hareket_gecmisi.append(islem) 
 
    def para_yatir(self, miktar): 
        if miktar > 0: 
            self.bakiye += miktar 
            self.islem_kaydet(f"+{miktar} TL yatırıldı.") 
            print(f"İşlem başarılı. Yeni bakiye: {self.bakiye} TL") 
        else: 
            print("Geçersiz tutar.") 
 
    def para_cek(self, miktar): 
        if miktar < 0: 
            print("Hata: Negatif para çekemezsiniz!") 
        elif miktar <= self.bakiye: 
            self.bakiye -= miktar 
            self.islem_kaydet(f"-{miktar} TL çekildi.") 
            print(f"Para çekildi. Kalan bakiye: {self.bakiye} TL") 
        else: 
            print("Yetersiz bakiye!") 
 
    def ozet(self): 
        print(f"\n--- {self.isim} Gün Sonu Özeti ---") 
        print(f"Mevcut Bakiye: {self.bakiye} TL") 
        print("İşlem Geçmişi:") 
        if not self.hareket_gecmisi: 
            print("Henüz bir işlem yapılmadı.") 
        for hareket in self.hareket_gecmisi: 
            print(hareket) 
 
3. Soru: Kütüphane Sistemi 
class Kitap: 
    def __init__(self, isim, yazar, **kwargs): 
        self.isim = isim 
        self.yazar = yazar 
        self.durum = "rafta" 
        # **kwargs ile kitap türü ekleme 
        self.turu = kwargs.get('turu', 'Belirtilmemiş') 
 
class Kullanici: 
    def __init__(self, isim): 
        self.isim = isim 
        self.aldigi_kitaplar = [] 
 
class Kutuphane: 
    def __init__(self): 
        self.kitaplar = [] 
 
    def kitap_ekleme(self, kitap): 
        self.kitaplar.append(kitap) 
        print(f"'{kitap.isim}' kütüphaneye eklendi.") 
 
    def odunc_verme(self, kitap, kullanici): 
        if kitap.durum == "odunc_verildi": 
            print(f"Hata: '{kitap.isim}' zaten başkasına verilmiş.") 
            return 
         
        if len(kullanici.aldigi_kitaplar) >= 2: 
            print(f"Hata: {kullanici.isim} en fazla 2 kitap 
alabilir.") 
            return 
         
        if kitap in self.kitaplar: 
            kitap.durum = "odunc_verildi" 
            kullanici.aldigi_kitaplar.append(kitap) 
            print(f"'{kitap.isim}', {kullanici.isim} adlı kullanıcıya 
ödünç verildi.") 
        else: 
            print("Böyle bir kitap kütüphanede yok.") 
 
    def iade_alma(self, kitap, kullanici): 
        if kitap in kullanici.aldigi_kitaplar: 
            kitap.durum = "rafta" 
            kullanici.aldigi_kitaplar.remove(kitap) 
            print(f"'{kitap.isim}' kütüphaneye iade edildi.") 
        else: 
            print(f"{kullanici.isim} bu kitabı almamış görünüyor.") 
 
4. Soru: Araç Kiralama Uygulaması 
class Arac: 
    def __init__(self, marka, gunluk_fiyat, *args): 
        self.marka = marka 
        self.gunluk_fiyat = gunluk_fiyat 
        self.musait_mi = True 
        # *args ile araç özelliklerini (otomatik, dizel vb.) tutuyoruz 
        self.ozellikler = args  
 
class Musteri: 
    def __init__(self, isim): 
        self.isim = isim 
        self.kiraladigi_araclar = [] 
 
    def arac_kirala(self, arac): 
        if arac.musait_mi: 
            arac.musait_mi = False 
            self.kiraladigi_araclar.append(arac) 
            print(f"{self.isim}, {arac.marka} aracını kiraladı.") 
        else: 
            print(f"Maalesef {arac.marka} şu an müsait değil.") 
 
    def arac_iade_et(self, arac): 
        if arac in self.kiraladigi_araclar: 
            arac.musait_mi = True 
            self.kiraladigi_araclar.remove(arac) 
            print(f"{self.isim}, {arac.marka} aracını iade etti.") 
        else: 
            print("Bu araç sizde kiralık görünmüyor.") 
 
5. Soru: Görev Takip Uygulaması 
class Gorev: 
    def __init__(self, baslik, aciklama, **kwargs): 
        self.baslik = baslik 
        self.aciklama = aciklama 
        self.tamamlandi_mi = False 
        # **kwargs ile öncelik ekleme 
        self.oncelik = kwargs.get('oncelik', 'Normal') 
 
class Kullanici: 
    def __init__(self, isim): 
        self.isim = isim 
        self.gorevler = [] 
        self.tamamlanan_gorevler = [] # Tamamlananlar için ayrı liste 
 
    def gorev_ekleme(self, yeni_gorev): 
        # Aynı görev ismi var mı diye kontrol edelim 
        for g in self.gorevler: 
            if g.baslik == yeni_gorev.baslik: 
                print(f"Hata: '{yeni_gorev.baslik}' adlı görev zaten 
var!") 
                return 
         
        self.gorevler.append(yeni_gorev) 
        print(f"Görev eklendi: {yeni_gorev.baslik} (Öncelik: 
{yeni_gorev.oncelik})") 
 
    def gorev_silme(self, gorev_baslik): 
        for g in self.gorevler: 
            if g.baslik == gorev_baslik: 
                self.gorevler.remove(g) 
                print(f"Görev silindi: {gorev_baslik}") 
                return 
        print("Böyle bir görev bulunamadı.") 
 
    def gorev_tamamlama(self, gorev_baslik): 
        for g in self.gorevler: 
            if g.baslik == gorev_baslik: 
                g.tamamlandi_mi = True 
                self.tamamlanan_gorevler.append(g) 
                self.gorevler.remove(g) 
                print(f"Tebrikler! '{gorev_baslik}' tamamlandı ve 
listeye alındı.") 
                return 
        print("Tamamlanacak görev bulunamadı.")
