class BankaHesabi: 
    def __init__(self, isim, bakiye): 
        self.isim = isim 
        self.bakiye = bakiye 
        self.hareket_gecmisi = [] 
 
    def para_yatir(self, miktar): 
        self.bakiye += miktar 
        self.hareket_gecmisi.append(f"{miktar} TL yatırıldı") 
 
    def para_cek(self, miktar): 
        if miktar < 0: 
            print("Negatif değer girilemez") 
        elif miktar <= self.bakiye: 
            self.bakiye -= miktar 
            self.hareket_gecmisi.append(f"{miktar} TL çekildi") 
        else: 
            print("Bakiye yetersiz") 
 
    def ozet(self): 
        print(f"Güncel Bakiye: {self.bakiye}") 
        for islem in self.hareket_gecmisi: 
            print(islem) 
 
